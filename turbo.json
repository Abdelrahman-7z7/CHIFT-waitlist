{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:staging": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "deploy:dry-run:staging": {
      "dependsOn": ["build"]
    },
    "deploy:dry-run:prod": {
      "dependsOn": ["build"]
    },
    "deploy:staging": {
      "dependsOn": ["build"]
    },
    "deploy:prod": {
      "dependsOn": ["build"]
    }
  }
}
