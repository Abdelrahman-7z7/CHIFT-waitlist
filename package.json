{
  "name": "chift-waitlist",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:staging": "turbo run dev:staging",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "bunx eslint --fix .",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "qa": "turbo run lint typecheck test && bun run format:check",
    "prepare": "husky",
    "deploy:dry-run:staging": "turbo run deploy:dry-run:staging",
    "deploy:dry-run:prod": "turbo run deploy:dry-run:prod",
    "deploy:staging": "turbo run deploy:staging",
    "deploy:prod": "turbo run deploy:prod",
    "db:generate": "turbo run generate --filter @repo/db",
    "db:migrate:local": "turbo run migrate:local --filter @repo/db",
    "db:migrate:staging": "turbo run migrate:staging --filter @repo/db",
    "db:migrate:prod": "turbo run migrate:prod --filter @repo/db",
    "db:clean:local": "wrangler d1 execute dojo_local_db --local --command \"DELETE FROM subscribers;\" --cwd apps/api",
    "test": "turbo run test",
    "test:db": "turbo run test --filter @repo/db"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "bun-types": "^1.3.13",
    "eslint": "^9.21.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "turbo": "latest",
    "typescript": "latest",
    "wrangler": "^4.86.0"
  }
}
