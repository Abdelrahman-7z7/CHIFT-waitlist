{
  "name": "chift-waitlist",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "bunx eslint --fix .",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "prepare": "husky",
    "deploy:dry-run:staging": "turbo run deploy:dry-run:staging",
    "deploy:dry-run:prod": "turbo run deploy:dry-run:prod",
    "deploy:staging": "turbo run deploy:staging",
    "deploy:prod": "turbo run deploy:prod"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "eslint": "^9.21.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "turbo": "latest",
    "typescript": "latest",
    "wrangler": "^4.86.0"
  }
}
