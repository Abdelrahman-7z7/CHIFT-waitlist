{
  "name": "@repo/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:staging": "BACKEND_API_URL=https://api-staging.chift.dev next dev -p 3000",
    "start": "next start",
    "build": "next build",
    "deploy:dry-run:staging": "next build",
    "deploy:dry-run:prod": "next build",
    "deploy:staging": "next-on-pages && wrangler pages deploy .vercel/output/static --project-name chift-web --branch staging",
    "deploy:prod": "next-on-pages && wrangler pages deploy .vercel/output/static --project-name chift-web --branch main",
    "lint": "next lint",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/ui": "workspace:*",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.12.0",
    "next": "15.1.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@repo/config": "workspace:*",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.3.13",
    "daisyui": "^5.5.19",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.3",
    "typescript": "^6.0.3"
  }
}
