{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev src/index.ts --port 8787",
    "build": "wrangler deploy --dry-run --outdir dist --config wrangler.toml --env production",
    "deploy:dry-run:staging": "wrangler deploy --dry-run --env staging",
    "deploy:dry-run:prod": "wrangler deploy --dry-run --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "start": "wrangler dev src/index.ts --port 8787",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@cloudflare/workers-types": "^4.20240405.0",
    "@repo/config": "workspace:*"
  }
}
