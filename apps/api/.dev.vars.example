"$schema" = ".........."
name = "............"
main = ".........."
# Set this to today's date
compatibility_date = "2026-04-29"
workers_dev = false
logpush = false
assets = { directory = "./public", binding = "ASSETS" }
[[d1_databases]]
binding = "DB"
database_name = ".........."
database_id = "..........."
migrations_dir = "../../packages/db/migrations"

[vars]
ENVIRONMENT = "dev"

[env.staging]
  logpush = false
  [[env.staging.d1_databases]]
  binding = "..."
  database_name = "..........."
  database_id = ".............."
  migrations_dir = "../../packages/db/migrations"

  [env.staging.vars]
  ENVIRONMENT = "staging"
  POLICY_AUD= ".............."
  CF_ACCESS_DOMAIN = "............"
  INTERNAL_SECRET = "............."

[env.production]
  logpush = false   
  [env.production.vars]
  ENVIRONMENT = "production"

